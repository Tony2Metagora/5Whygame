# Azure OpenAI — ressource unique (endpoint + clé)
# Ex. France Central (Foundry) : https://francecentral.api.cognitive.microsoft.com
AZURE_OPENAI_ENDPOINT=https://YOUR_RESOURCE.openai.azure.com
AZURE_OPENAI_API_KEY=

# Optionnel : clé différente pour Realtime uniquement
# AZURE_OPENAI_REALTIME_API_KEY=

# Version API pour chat completions (+ Whisper si Azure)
AZURE_OPENAI_API_VERSION=2024-12-01-preview

# API Responses (nano sur Foundry — URL portail /openai/responses) ; utilisée si chat 404 ou AZURE_OPENAI_CHAT_API=responses
AZURE_OPENAI_RESPONSES_API_VERSION=2025-04-01-preview
# chat | responses | auto (défaut) — auto réessaie avec Responses si Resource not found sur chat
# AZURE_OPENAI_CHAT_API=auto

# Déploiements
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-5.4-mini
AZURE_OPENAI_WHISPER_DEPLOYMENT=whisper

# Realtime (WebRTC) — ex. portail Azure « gpt-realtime-1.5 »
AZURE_OPENAI_REALTIME_DEPLOYMENT=gpt-realtime-1.5
# Voix sortie : alloy, ash, ballad, coral, echo, sage, shimmer, verse, marin…
# AZURE_OPENAI_REALTIME_VOICE=alloy

# WebSocket preview uniquement (outil `buildAzureRealtimePreviewWebSocketUrl`) — pas pour client_secrets GA
AZURE_OPENAI_REALTIME_API_VERSION=2024-10-01-preview
